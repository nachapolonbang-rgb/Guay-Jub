generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Order {
  id          Int      @id @default(autoincrement())
  total       Float
  status      String   @default("new")
  paymentStatus String @default("pending") // 'pending' | 'paid' | 'cancelled'
  paymentMethod String? // 'cash' | 'qr'
  createdAt   DateTime @default(now())
  items       OrderItem[]

  guestName   String?
  guestPhone  String?
  orderType   String   @default("dine-in")
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
}

model OrderItem {
  id      Int    @id @default(autoincrement())
  orderId Int
  name    String
  price   Float
  qty     Int

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  removedIngredients String @default("[]")
  toppings           String @default("[]")
  note               String @default("")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String?
  role     String   @default("USER")
  orders   Order[]  // ✅ เพิ่ม relation กลับ
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  price       Float
  cost        Float
  sold        Int      @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients String @default("[]")
  toppings    String @default("[]")
}

model Promotion {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  detail      String?
  date        String
  status      String   @default("active") // 'active' | 'upcoming' | 'ended'
  tag         String   @default("ข่าวสาร") // 'ข่าวสาร' | 'เมนูใหม่' | 'กิจกรรม' | 'ประกาศ' | 'โปรโมชั่น'
  emoji       String   @default("📢")
  discount    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiscountCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  type        String   // 'fixed' | 'percent'
  value       Float
  minOrder    Float    @default(0)
  usedCount   Int      @default(0)
  maxUses     Int?
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id        Int      @id @default(autoincrement())
  name      String
  qty       Float
  unit      String
  minQty    Float
  cost      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs InventoryLog[]
}

model InventoryLog {
  id        Int           @id @default(autoincrement())
  itemId    Int
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  prevQty   Float
  newQty    Float
  changedBy String        @default("staff")
  note      String?
  createdAt DateTime      @default(now())
}

// เพิ่มใน prisma/schema.prisma

model ShopSettings {
  id           Int      @id @default(1) // singleton row — always id=1
  shopName     String   @default("ร้านก๋วยจั๊บป้าแดง")
  shopPhone    String   @default("081-234-5678")
  shopAddress  String   @default("123 ถ.สุขุมวิท กรุงเทพฯ")
  shopNote     String   @default("เปิดทุกวัน ยกเว้นวันพุธ")
  isOpen       Boolean  @default(true)

  // hours: JSON array of 7 OpenHour objects (Mon–Sun)
  // [{ open: "08:00", close: "16:00", closed: false }, ...]
  hours        String   @default("[]")

  // notification toggles
  notifNew      Boolean @default(true)
  notifLowStock Boolean @default(true)
  notifDaily    Boolean @default(false)
  dailyTime     String  @default("22:00")

  updatedAt    DateTime @updatedAt
}

// หลังเพิ่มแล้วรัน:
// npx prisma migrate dev --name add-shop-settings