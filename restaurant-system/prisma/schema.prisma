generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Order {
  id        Int      @id @default(autoincrement())
  total     Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  items     OrderItem[]
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  orderId Int
  name    String
  price   Float
  qty     Int

  order   Order @relation(fields: [orderId], references: [id])
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String?
  role     String @default("USER") // ✅ สำคัญ
}